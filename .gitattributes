# 1. DEFAULT TEXT HANDLING
# Treat all files as text and normalize line endings unless specified otherwise
* text=auto

# 2. SOURCE CODE (Force LF line endings)
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf

# 3. UNITY TEXT ASSETS (Crucial for preventing merge mess)
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.mat text eol=lf

# 4. BINARY FILES (Never touch the contents of these)
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.psd binary
*.fbx binary
*.wav binary
*.mp3 binary
*.ogg binary

# 5. LFS OVERRIDES (The "Final Word")
# These must be at the bottom to ensure they override any 'text' settings above
*.png filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text